{
  "name": "sbtc-escrow-tests",
  "version": "1.0.0",
  "description": "sBTC Escrow V2 - Trustless Payments on Stacks",
  "type": "module",
  "private": true,
  "scripts": {
    "test": "vitest run",
    "test:report": "vitest run -- --coverage --costs",
    "test:watch": "chokidar \"tests/**/*.ts\" \"contracts/**/*.clar\" -c \"npm run test:report\"",
    "deploy:testnet": "npx tsx scripts/deploy-testnet.ts",
    "test:testnet": "npx tsx scripts/test-testnet.ts",
    "test:testnet:full": "npx tsx scripts/test-testnet-full.ts"
  },
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@stacks/clarinet-sdk": "^3.9.0",
    "@stacks/network": "^7.3.1",
    "@stacks/transactions": "^7.2.0",
    "@stacks/wallet-sdk": "^7.2.0",
    "@types/node": "^24.4.0",
    "chokidar-cli": "^3.0.0",
    "tsx": "^4.21.0",
    "vitest": "^4.0.7",
    "vitest-environment-clarinet": "^3.0.0",
    "yaml": "^2.8.2"
  }
}
