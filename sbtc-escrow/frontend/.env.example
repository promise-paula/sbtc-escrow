# sBTC Escrow Frontend — Environment Variables
# Copy to .env and fill in values

# Required: Supabase connection
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Network configuration (defaults to testnet if not set)
VITE_STACKS_NETWORK=testnet
# VITE_STACKS_API_URL=https://api.testnet.hiro.so  # auto-derived from VITE_STACKS_NETWORK

# Contract addresses (defaults to testnet contracts if not set)
# VITE_CONTRACT_ADDRESS=ST1HK6H018TMMZ1BZPS1QMJZE9WPA7B93T8ZHV94N
# VITE_CONTRACT_NAME=escrow-v4
# VITE_SBTC_CONTRACT=ST1F7QA2MDF17S807EPA36TSS8AMEFY4KA9TVGWXT.sbtc-token
